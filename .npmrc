# Supply-chain hardening (audit S11): do NOT auto-run any dependency install/lifecycle
# scripts on install. Native modules are rebuilt EXPLICITLY instead — CI/build use
# `npm rebuild <pkg> --ignore-scripts=false` (node ABI) and `npm run rebuild`
# (electron-rebuild CLI, electron ABI). This stops a compromised transitive dep from
# executing arbitrary code at install time on the signing host.
ignore-scripts=true
